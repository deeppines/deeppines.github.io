{
  "name": "deeppines",
  "version": "0.0.0",
  "description": "home page",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint --fix \"./src/**/*.ts*\"",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "fix": "yarn lint && yarn format",
    "check:ci": "eslint \"./src/**/*.ts*\" && yarn run lint:styles && jest --ci --passWithNoTests",
    "test": "jest --watch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{js,jsx,json,css,md,mdx,yml}": "prettier --write",
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{test.js,test.jsx,test.ts,test.tsx}": "yarn jest --passWithNoTests"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "post-commit": "git update-index --again"
    }
  },
  "author": "@deeppines",
  "license": "ISC",
  "packageManager": "yarn@4.17.0",
  "dependencies": {
    "@tabler/icons": "3.44.0",
    "normalize.css": "8.0.1",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "9.39.4",
    "@types/babel__core": "7.20.5",
    "@types/babel__preset-env": "7.10.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.0.0",
    "babel-jest": "30.4.1",
    "eslint": "9.39.4",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "lint-staged": "17.0.8",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "rollup-plugin-visualizer": "7.0.1",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-plugin-compression2": "2.5.3",
    "vite-plugin-open-graph": "2.0.6"
  }
}
